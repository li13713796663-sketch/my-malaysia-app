# 复制为 .streamlit/secrets.toml

[postgres]
# 推荐：Session Pooler（IPv4，适合 Windows / 国内网络）
conn_str = "postgresql://postgres.你的项目ID:你的密码@aws-0-ap-southeast-1.pooler.supabase.com:5432/postgres?sslmode=require"

# 可选：单独指定 Pooler（优先级高于 conn_str）
# pooler_conn_str = "postgresql://postgres.你的项目ID:你的密码@aws-0-ap-southeast-1.pooler.supabase.com:5432/postgres?sslmode=require"

# 直连（db.xxx.supabase.co）在国内常因仅 IPv6 导致 DNS 失败，不推荐本地开发使用
# conn_str = "postgresql://postgres:密码@db.xxx.supabase.co:5432/postgres?sslmode=require"

# 获取方式：Supabase 控制台 → Project Settings → Database → Connection Pooling → Session mode
